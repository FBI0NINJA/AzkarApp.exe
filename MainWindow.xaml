<Window x:Class="AzkarApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azkar App" Height="474" Width="511"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#111" HorizontalAlignment="Center" Width="511" Height="521" VerticalAlignment="Bottom" Margin="0,0,0,-63">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Column="2" Height="213" Width="220" Margin="0,35,0,0">

            <TextBlock Text="📿 أذكار المسلم"
                       Foreground="White"
                       FontSize="30"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="ZekrText"
                       Text="سبحان الله"
                       Foreground="White"
                       FontSize="22"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15" Height="34" Width="96"/>

            <TextBlock x:Name="CounterText"
                       Text="0"
                       Foreground="#ff66cc"
                       FontSize="40"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="تسبيح"
                        Width="100"
                        Margin="5"
                        Click="Tasbeeh_Click"/>
                <Button Content="إعادة"
                        Width="100"
                        Margin="5"
                        Click="Reset_Click"/>
                <StackPanel/>
            </StackPanel>

        </StackPanel>
        <Button Content="Facebook" Click="Facebook_Click" Grid.ColumnSpan="3" FontSize="17" Foreground="#66ccff" Background="#111" Margin="347,312,29,152"/>
        <Button Content="GitHub" Click="Github_Click" Grid.ColumnSpan="3" FontSize="17" Foreground="#66ccff" Background="#111" Margin="26,312,350,152"/>
        <TextBlock x:Name="ZekrText_Copy"
            Foreground="red"
            FontSize="12"
    Grid.ColumnSpan="3" Margin="190,333,74,59"><Run FlowDirection="RightToLeft" Language="ar-sa" Text="Created by Ahmed Sayed"/></TextBlock>
    </Grid>
</Window>